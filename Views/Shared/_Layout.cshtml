@using Microsoft.AspNetCore.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> L

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MyApp</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        * { font-family: 'Inter', sans-serif; }

        /* Navbar */
        .navbar { background: #fff !important; border-bottom: 1px solid #eef0f3; padding: 1rem 0; }
        .navbar-brand { font-weight: 800; font-size: 1.2rem; color: #0d1f3c !important; }
        .navbar-nav .nav-link { color: #4a5568 !important; font-weight: 500; font-size: 0.95rem; padding: 0.4rem 1rem !important; }
        .navbar-nav .nav-link:hover { color: #0d1f3c !important; }
        .btn-cta { background: #0d1f3c; color: #fff; border-radius: 50px; padding: 0.5rem 1.4rem; font-weight: 600; font-size: 0.9rem; border: none; }
        .btn-cta:hover { background: #1a3560; color: #fff; }
        .navbar-toggler { border: none; }
        .dropdown-menu { border: 1px solid #eef0f3; border-radius: 10px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
        .dropdown-item { color: #4a5568; font-weight: 500; font-size: 0.9rem; }
        .dropdown-item:hover { color: #0d1f3c; background: #f7f9fc; }
        .navbar-text { color: #4a5568 !important; font-size: 0.9rem; }

        /* Language switcher */
        .lang-btn { background: none; border: 1.5px solid #e2e8f0; border-radius: 50px; padding: 0.25rem 0.8rem; font-size: 0.82rem; font-weight: 600; color: #4a5568; cursor: pointer; }
        .lang-btn:hover, .lang-btn.active { border-color: #0d1f3c; color: #0d1f3c; }

        /* General */
        body { background: #fff; color: #0d1f3c; }
        .page-content { padding-top: 0; }

        /* Shared buttons */
        .btn-primary-dark { background: #0d1f3c; color: #fff; border-radius: 50px; padding: 0.75rem 1.8rem; font-weight: 600; border: none; display: inline-flex; align-items: center; gap: 0.4rem; }
        .btn-primary-dark:hover { background: #1a3560; color: #fff; }
        .btn-outline-dark-rounded { border: 2px solid #0d1f3c; color: #0d1f3c; border-radius: 50px; padding: 0.75rem 1.8rem; font-weight: 600; background: transparent; }
        .btn-outline-dark-rounded:hover { background: #0d1f3c; color: #fff; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">MyApp</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon" style="filter:invert(1) brightness(0);"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">@L["Nav_Home"]</a>
                    </li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">@L["Nav_Admin"]</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-area="Admin" asp-controller="Users" asp-action="Index">@L["Nav_UserManagement"]</a></li>
                            </ul>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav align-items-center gap-2">
                    @{
                        var currentCulture = Context.Features.Get<IRequestCultureFeature>()?.RequestCulture.Culture.Name ?? "en";
                        var returnUrl = Context.Request.Path + Context.Request.QueryString;
                    }
                    <li class="nav-item d-flex gap-1">
                        <form asp-controller="Culture" asp-action="Set" method="post">
                            <input type="hidden" name="culture" value="en" />
                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                            <button type="submit" class="lang-btn @(currentCulture.StartsWith("en") ? "active" : "")">EN</button>
                        </form>
                        <form asp-controller="Culture" asp-action="Set" method="post">
                            <input type="hidden" name="culture" value="fr" />
                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                            <button type="submit" class="lang-btn @(currentCulture.StartsWith("fr") ? "active" : "")">FR</button>
                        </form>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <span class="navbar-text">@User.Identity.Name</span>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="btn-cta">@L["Nav_Logout"]</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a asp-controller="Account" asp-action="Login" class="btn-cta text-decoration-none">@L["Nav_Login"]</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="page-content">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
