@using Microsoft.AspNetCore.Identity
@model IEnumerable<IdentityUser>

@{
    ViewData["Title"] = L["Users_Title"];
    var userRoles = ViewBag.UserRoles as Dictionary<string, string>;
}

<style>
    .admin-page { padding: 50px 0; min-height: calc(100vh - 73px); background: #f7f9fc; }
    .admin-card { background: #fff; border-radius: 16px; padding: 2rem; box-shadow: 0 2px 20px rgba(0,0,0,0.06); }
    .admin-card h2 { font-size: 1.6rem; font-weight: 800; color: #0d1f3c; }
    .btn-new { background: #0d1f3c; color: #fff; border-radius: 50px; padding: 0.5rem 1.4rem; font-weight: 600; font-size: 0.9rem; border: none; text-decoration: none; }
    .btn-new:hover { background: #1a3560; color: #fff; }
    .table thead th { font-size: 0.82rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #5a6a7e; border-bottom: 2px solid #eef0f3; background: transparent; }
    .table td { vertical-align: middle; color: #0d1f3c; font-size: 0.93rem; border-color: #f0f2f5; }
    .role-badge { display: inline-block; background: #e8f0fb; color: #1a6fbf; border-radius: 50px; padding: 0.2rem 0.8rem; font-size: 0.78rem; font-weight: 600; }
    .role-badge.none { background: #f0f2f5; color: #a0aec0; }
    .btn-action { border-radius: 50px; padding: 0.3rem 0.9rem; font-size: 0.82rem; font-weight: 600; }
</style>

<div class="admin-page">
    <div class="container">
        <div class="admin-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>@L["Users_Title"]</h2>
                <a asp-action="Create" class="btn-new">@L["Users_NewUser"]</a>
            </div>
            <table class="table">
                <thead>
                    <tr>
                        <th>@L["Users_Email"]</th>
                        <th>@L["Users_Role"]</th>
                        <th style="width:160px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        var role = userRoles?[user.Id] ?? "-";
                        <tr>
                            <td>@user.Email</td>
                            <td><span class="role-badge @(role == "-" ? "none" : "")">@role</span></td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-secondary btn-action me-1">@L["Users_Edit"]</a>
                                <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-outline-danger btn-action">@L["Users_Delete"]</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
